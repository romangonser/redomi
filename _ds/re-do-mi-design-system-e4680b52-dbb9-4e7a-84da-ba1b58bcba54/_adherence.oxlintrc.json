{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/badges/**",
              "components/brand/**",
              "components/buttons/**",
              "components/cards/**",
              "components/footer/**",
              "components/icons/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Josefin Sans|Lato|Playfair Display))/i]",
        "message": "Font not provided by the design system. Available: Josefin Sans, Lato, Playfair Display."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|nav)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'nav'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<CategoryBadge> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|label|sub|href|key|ref|className|style|children)$/]",
        "message": "<CategoryCard> doesn't accept that prop. Declared props: image, label, sub, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='DesignerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|name|discipline|location|href|key|ref|className|style|children)$/]",
        "message": "<DesignerCard> doesn't accept that prop. Declared props: image, name, discipline, location, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|items|key|ref|className|style|children)$/]",
        "message": "<FooterColumn> doesn't accept that prop. Declared props: heading, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|showWordmark|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, size, showWordmark."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ink|light)$/]",
        "message": "<Logo> variant must be one of 'ink' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Navbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:announcement|links|activeIndex|onLogin|loggedIn|key|ref|className|style|children)$/]",
        "message": "<Navbar> doesn't accept that prop. Declared props: announcement, links, activeIndex, onLogin, loggedIn."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|category|title|designer|price|href|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: image, category, title, designer, price, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='SeeAllLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|key|ref|className|style|children)$/]",
        "message": "<SeeAllLink> doesn't accept that prop. Declared props: children, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialProofCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|author|role|featured|key|ref|className|style|children)$/]",
        "message": "<SocialProofCard> doesn't accept that prop. Declared props: quote, author, role, featured."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
